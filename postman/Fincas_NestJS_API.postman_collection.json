              "raw": "{{base_url}}/api/fincas?limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "fincas"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Número de resultados"
                },
                {
                  "key": "location",
                  "value": "Girardot",
                  "description": "Filtrar por ubicación"
                },
                {
                  "key": "minCapacity",
                  "value": "10",
                  "description": "Capacidad mínima"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "Cursor para paginación",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "",
                  "description": "FINCA, CASA_CAMPESTRE, VILLA, etc.",
                  "disabled": true
                },
                {
                  "key": "category",
                  "value": "",
                  "description": "ECONOMICA, ESTANDAR, PREMIUM, etc.",
                  "disabled": true
                },
                {
                  "key": "maxPrice",
                  "value": "",
                  "description": "Precio máximo",
                  "disabled": true
                },
                {
                  "key": "isFavorite",
                  "value": "true",
                  "description": "Filtrar por favoritos (true/false)",
                  "disabled": true
                }
              ]
            }
          }
        },
